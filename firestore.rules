// ============================================================
// FIREBASE FIRESTORE SECURITY RULES
// Copy this EXACTLY into Firebase Console:
// Firestore → Rules → Edit → Paste → Publish
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isMember() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'member';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users collection ──────────────────────────────────
    // Members can read/write their own doc. Admins can read all.
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isAuth() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Members collection ────────────────────────────────
    // Only admins can write. Members can read their own record.
    match /members/{memberId} {
      allow read:   if isAdmin() || (isMember() &&
        resource.data.phone == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phone);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Payments collection ───────────────────────────────
    // Only admins can write. Members can read their own payments.
    match /payments/{paymentId} {
      allow read:   if isAdmin() || (isMember() &&
        resource.data.memberId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.memberId);
      allow create: if isAdmin() || isMember(); // members create via Razorpay webhook
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── BCA readings ──────────────────────────────────────
    // Admins can read/write all. Members can only read their own.
    match /bca_readings/{readingId} {
      allow read:   if isAdmin() || (isMember() &&
        resource.data.memberId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.memberId);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Steam bookings ────────────────────────────────────
    // Members can create/cancel their own. Admins manage all.
    match /steam_bookings/{bookingId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isMember() &&
        resource.data.memberId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.memberId);
    }

    // ── Attendance ────────────────────────────────────────
    // Admins write (check-in). Members read own. QR system writes.
    match /attendance/{docId} {
      allow read:   if isAdmin() || (isMember() &&
        resource.data.memberId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.memberId);
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────
    match /notifications/{docId} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Workout plans (custom by trainer) ─────────────────
    match /workout_plans/{planId} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
